<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:ClassModifier="internal">
  <ControlTheme x:Key="{x:Type GridSplitter}"
                TargetType="GridSplitter">
    <Setter Property="Focusable" Value="True" />
    <Setter Property="MinWidth" Value="8" />
    <Setter Property="MinHeight" Value="8" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="ShowsPreview" Value="True" />
    <Setter Property="PreviewContent">
      <Template>
        <Rectangle Fill="{DynamicResource UnitySelectionBrush}" Opacity="0.5" />
      </Template>
    </Setter>
    <Setter Property="Template">
      <ControlTemplate>
        <Panel Background="Transparent">
          <Border Name="VerticalSeam"
                  Width="1"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Stretch"
                  Background="{DynamicResource UnityBorderLightBrush}" />
          <Border Name="HorizontalSeam"
                  Height="1"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Stretch"
                  Background="{DynamicResource UnityBorderLightBrush}" />
        </Panel>
      </ControlTemplate>
    </Setter>

    <!-- Auto/Columns: vertical seam only. Rows: horizontal seam only. -->
    <Style Selector="^ /template/ Border#HorizontalSeam">
      <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="^[ResizeDirection=Rows] /template/ Border#HorizontalSeam">
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <Style Selector="^[ResizeDirection=Rows] /template/ Border#VerticalSeam">
      <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="^:pointerover /template/ Border#VerticalSeam,
                     ^:pointerover /template/ Border#HorizontalSeam">
      <Setter Property="Background" Value="{DynamicResource ThemeBorderHighBrush}" />
    </Style>
  </ControlTheme>
</ResourceDictionary>
