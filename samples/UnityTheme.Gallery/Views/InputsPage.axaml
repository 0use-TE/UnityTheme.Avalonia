<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:UnityTheme.Gallery.Views"
             x:Class="UnityTheme.Gallery.Views.InputsPage">
  <StackPanel Spacing="12">
    <StackPanel Spacing="6" MaxWidth="280">
      <Label Content="Aligned inputs" />
      <Label Content="Same width &amp; height" />
      <TextBox Text="TextBox" />
      <ComboBox SelectedIndex="0">
        <ComboBoxItem Content="ComboBox item" />
      </ComboBox>
      <NumericUpDown Minimum="0" Maximum="100" Value="42" />
      <AutoCompleteBox PlaceholderText="AutoCompleteBox"
                       ItemsSource="{x:Static views:GallerySampleData.AutoCompleteInputs}" />
    </StackPanel>

    <StackPanel Spacing="8" MaxWidth="360">
      <Label Content="Property fields" />
      <TextBox PlaceholderText="Object name" />
      <TextBox Text="Transform.localPosition" IsReadOnly="True" />
      <TextBox PlaceholderText="Multi-line notes" AcceptsReturn="True" Height="72" />
      <NumericUpDown Width="120" Increment="0.1" FormatString="F2" Value="1.0" />
      <ComboBox PlaceholderText="Shader" SelectedIndex="0">
        <ComboBoxItem Content="Standard" />
        <ComboBoxItem Content="Unlit/Color" />
        <ComboBoxItem Content="UI/Default" />
      </ComboBox>
      <Slider Minimum="0" Maximum="100" Value="42" />
      <ProgressBar Minimum="0" Maximum="100" Value="72" ShowProgressText="True" />
    </StackPanel>
  </StackPanel>
</UserControl>
